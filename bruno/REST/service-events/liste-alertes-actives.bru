meta {
  name: liste-alertes-actives
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/alerts?status=ACTIVE
  body: none
  auth: inherit
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("toutes les alertes ont le statut ACTIVE", function() {
    const body = res.getBody();
    expect(body).to.be.an('array');
    body.forEach(function(alert) {
      expect(alert.status).to.equal('ACTIVE');
    });
  });
}
