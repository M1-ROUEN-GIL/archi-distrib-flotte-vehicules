meta {
  name: get-drivers
  type: graphql
  seq: 1
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    drivers {
      items {
        id
        first_name
        last_name
        email
        status
      }
    }
  }
}

script:post-response {
  const items = res.getBody()?.data?.drivers?.items;
  if (items && items.length > 0) {
    bru.setVar('gql_driver_id', items[0].id);
  }
}
