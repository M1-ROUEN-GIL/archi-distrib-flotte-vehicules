meta {
  name: get-vehicules
  type: graphql
  seq: 1
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    vehicles {
      id
      plate_number
      brand
      model
      mileage_km
      status
    }
  }
}

script:post-response {
  const vehicles = res.getBody()?.data?.vehicles;
  if (vehicles && vehicles.length > 0) {
    bru.setVar('gql_vehicle_id', vehicles[0].id);
  }
}
