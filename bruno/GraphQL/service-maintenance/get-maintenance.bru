meta {
  name: get-maintenance
  type: graphql
  seq: 1
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    maintenanceRecords {
      items {
        id
        description
        status
      }
    }
  }
}

script:post-response {
  const items = res.getBody()?.data?.maintenanceRecords?.items;
  if (items && items.length > 0) {
    bru.setVar('gql_maintenance_id', items[0].id);
  }
}
